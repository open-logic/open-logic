CAPI=2:

name : "open-logic:open-logic-dev:ft:4.5.0"
description : "local files (release plus WIP); Fault tolerant circuitry (e.g. SECDED protected RAMs, scrubbers, ...) see https://github.com/open-logic/open-logic/blob/main/doc/EntityList.md#ft"

filesets:
  rtl:
    files:
      - "vhdl/olo_ft_ecc_decode.vhd"
      - "vhdl/olo_ft_ecc_encode.vhd"
      - "vhdl/olo_ft_pkg_ecc.vhd"
      - "vhdl/olo_ft_private_scrubber.vhd"
      - "vhdl/olo_ft_ram_sdp.vhd"
      - "vhdl/olo_ft_ram_sdp_scrub.vhd"
      - "vhdl/olo_ft_ram_sp.vhd"
      - "vhdl/olo_ft_ram_sp_scrub.vhd"
      - "vhdl/olo_ft_ram_tdp.vhd"
    file_type : "vhdlSource-2008"
    logical_name : "olo"
    depend :
      - "^open-logic:open-logic-dev:base:4.5.0"


targets:
  default:
    filesets :
      - "rtl"
  